# Navio RPC connection
RPC_HOST=127.0.0.1
RPC_PORT=33677
RPC_USER=
RPC_PASSWORD=

# API server
API_PORT=3001

# Network: mainnet or testnet (affects block reward calculation)
NETWORK=mainnet

# Optional comma-separated bootstrap nodes for direct P2P crawl
TESTNET_BOOTSTRAP_NODES=testnet.nav.io,testnet2.nav.io
# Optional comma-separated bootstrap nodes for mainnet direct crawl
MAINNET_BOOTSTRAP_NODES=
# Optional explicit P2P port override for all networks
# P2P_PORT=
# Network-specific default P2P ports
TESTNET_P2P_PORT=33670
MAINNET_P2P_PORT=8333
# Optional message-start override (8 hex chars). If set, this overrides network-specific magic.
# P2P_MESSAGE_MAGIC_HEX=
P2P_TESTNET_MAGIC_HEX=1c03bb83
P2P_MAINNET_MAGIC_HEX=dbd2b1ac
# Direct P2P protocol/crawler controls
P2P_PROTOCOL_VERSION=70016
P2P_REQUEST_TIMEOUT_MS=4500
P2P_CRAWL_CONCURRENCY=24
PEER_DISCOVERY_ROUNDS=3
PEER_DISCOVERY_BATCH_SIZE=64
PEER_DISCOVERY_WAIT_MS=1200
PEER_DISCOVERY_MAX_CANDIDATES=2000
PEER_CONNECT_TIMEOUT_MS=2000
PEER_CONNECT_CONCURRENCY=48
PEER_CONNECT_TEST_LIMIT=300
PEER_DISCOVERY_FILTER_UNREACHABLE=true
PEER_GEO_LOOKUP_LIMIT=80

# MEXC price symbols
MEXC_NAV_SYMBOL=NAVUSDT
MEXC_BTC_SYMBOL=BTCUSDT

# Database path (relative to project root)
DB_PATH=./navio-blocks.db

# Frontend API URL
VITE_API_URL=http://localhost:3002
