# Navio RPC connection
RPC_HOST=127.0.0.1
RPC_PORT=33677
RPC_USER=
RPC_PASSWORD=

# API server
API_PORT=3001
# Optional absolute base URL shown in Swagger/OpenAPI docs server list
# Example: https://blocks.nav.io
# PUBLIC_API_URL=

# Network: mainnet or testnet (affects block reward calculation)
NETWORK=mainnet

# Optional comma-separated bootstrap nodes for direct P2P crawl
TESTNET_BOOTSTRAP_NODES=testnet.nav.io,testnet2.nav.io
# Optional comma-separated bootstrap nodes for mainnet direct crawl
MAINNET_BOOTSTRAP_NODES=
# Optional explicit P2P port override for all networks
# P2P_PORT=
# Network-specific default P2P ports
TESTNET_P2P_PORT=33670
MAINNET_P2P_PORT=48471
# Optional message-start override (8 hex chars). If set, this overrides network-specific magic.
# P2P_MESSAGE_MAGIC_HEX=
P2P_TESTNET_MAGIC_HEX=1c03bb83
P2P_MAINNET_MAGIC_HEX=bd5fc300
# Direct P2P protocol/crawler controls
P2P_PROTOCOL_VERSION=70016
P2P_REQUEST_TIMEOUT_MS=4500
P2P_CRAWL_CONCURRENCY=24
PEER_DISCOVERY_ROUNDS=3
PEER_DISCOVERY_BATCH_SIZE=64
PEER_DISCOVERY_WAIT_MS=1200
PEER_DISCOVERY_MAX_CANDIDATES=2000
PEER_CONNECT_TIMEOUT_MS=2000
PEER_CONNECT_CONCURRENCY=48
PEER_CONNECT_TEST_LIMIT=300
PEER_DISCOVERY_FILTER_UNREACHABLE=true
PEER_GEO_LOOKUP_LIMIT=80

# MEXC price symbols
MEXC_NAV_SYMBOL=NAVUSDT
MEXC_BTC_SYMBOL=BTCUSDT

# Database path (relative to project root)
DB_PATH=./navio-blocks.db

# Frontend API URL
VITE_API_URL=http://localhost:3002

# --- Optional: BSC wNAV bridge burn indexing (indexer) ---
# BSC_WNAV_ENABLED=1
# Pick BSC mainnet (chain id 56) or BSC testnet (97). Defaults to navio NETWORK,
# i.e. NETWORK=testnet → BSC testnet, NETWORK=mainnet → BSC mainnet.
# BSC_CHAIN=mainnet
# wNAV BEP-20 contract address. Default is the BSC mainnet deployment; for
# testnet you MUST set this to the testnet wNAV contract.
# BSC_WNAV_ADDRESS=0x...
# BSC_HTTP_URL=https://bsc-rpc.publicnode.com
# BSC_WSS_URL=wss://bsc-rpc.publicnode.com
# Override Navio note prefix (default: nav1 mainnet, tnv1 testnet)
# BSC_WNAV_NOTE_PREFIX=
# Diagnostics: log every poll cycle's scanned block range
# BSC_WNAV_DEBUG=1
# BSC_WNAV_POLL_INTERVAL_MS=30000
# BSC_WNAV_HEARTBEAT_INTERVAL_MS=60000

# --- Optional: BLSCT audit wallet via navio-sdk (indexer, Node >= 20.19) ---
# NAVIO_AUDIT_KEY=
# NAVIO_AUDIT_WALLET_PATH=./navio-audit-wallet.db
# NAVIO_AUDIT_RESTORE_HEIGHT=0
# NAVIO_ELECTRUM_HOST=
# NAVIO_ELECTRUM_PORT=
# NAVIO_ELECTRUM_SSL=true
# NAVIO_AUDIT_INTERVAL_MS=900000
