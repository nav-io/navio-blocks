{
  "name": "@navio-blocks/indexer",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "patch-navio-sdk": "node ../../scripts/patch-navio-sdk-external-better-sqlite3.cjs",
    "predev": "npm run patch-navio-sdk",
    "prestart": "npm run patch-navio-sdk",
    "prereindex": "npm run patch-navio-sdk",
    "prereindex:from": "npm run patch-navio-sdk",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "reindex": "tsx src/index.ts --reindex",
    "reindex:from": "tsx src/index.ts --from"
  },
  "dependencies": {
    "@navio-blocks/shared": "*",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.0",
    "navio-sdk": "^0.1.13",
    "viem": "^2.48.4"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
